{
  "name": "mcp-studio",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "A professional desktop application for working with MCP servers — universal client + Niagara/BMS specialization.",
  "license": "UNLICENSED",
  "author": "Mikhail (mefodiytr)",
  "engines": {
    "node": ">=20"
  },
  "packageManager": "pnpm@11.0.9",
  "scripts": {
    "dev": "pnpm --filter @mcp-studio/desktop dev",
    "build": "pnpm --filter @mcp-studio/desktop build",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "typecheck": "pnpm -r --if-present typecheck",
    "test": "pnpm -r --if-present test",
    "test:e2e": "pnpm build && playwright test --config tests/e2e/playwright.config.ts"
  },
  "devDependencies": {
    "@eslint/js": "^9.18.0",
    "@playwright/test": "^1.59.1",
    "@types/node": "^22.10.5",
    "eslint": "^9.18.0",
    "eslint-config-prettier": "^9.1.0",
    "prettier": "^3.4.2",
    "typescript": "^5.7.3",
    "typescript-eslint": "^8.20.0"
  }
}
